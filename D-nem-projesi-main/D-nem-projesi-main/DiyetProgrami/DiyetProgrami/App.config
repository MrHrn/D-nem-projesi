<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<connectionStrings>
		<add name="DiyetProgramiConnectionString"
			 connectionString="Server=(localdb)\MSSQLLocalDB;Database=veritabanıadı;Trusted_Connection=True;MultipleActiveResultSets=True;Connect Timeout=30;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>

